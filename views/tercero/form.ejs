<%- include('../partials/head') %>
<div class="d-flex">
<%- include('../partials/sidebar') %>
<div class="main-content w-100">
  <%- include('../partials/topbar') %>
  <div class="p-4">
    <%- include('../partials/alerts') %>
    <div class="card" style="max-width:900px">
      <div class="card-header bg-white border-0 pt-3 px-4">
        <h6 class="fw-semibold mb-0"><%= pageTitle %></h6>
      </div>
      <div class="card-body px-4 pb-4">
        <form method="POST" action="<%= action %>">

          <div class="row g-3">
            <div class="col-md-4">
              <label class="form-label fw-semibold small">NIT / CC <span class="text-danger">*</span></label>
              <input type="text" name="nit" class="form-control"
                     value="<%= tercero?tercero.nit:'' %>" required maxlength="15">
            </div>
            <div class="col-md-2">
              <label class="form-label fw-semibold small">Digito V.</label>
              <input type="text" name="digito_vf" class="form-control"
                     value="<%= tercero&&tercero.digito_vf?tercero.digito_vf:'' %>" maxlength="1">
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold small">Razon Social / Nombre Completo <span class="text-danger">*</span></label>
              <input type="text" name="razon_social" class="form-control"
                     value="<%= tercero?tercero.razon_social:'' %>" required maxlength="150">
            </div>

            <div class="col-md-4">
              <label class="form-label fw-semibold small">Tipo <span class="text-danger">*</span></label>
              <select name="tipo" class="form-select" required>
                <% tipos.forEach(t=>{ %>
                <option value="<%= t %>" <%=tercero&&tercero.tipo===t?'selected':''%>><%= t %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label fw-semibold small">Regimen Tributario</label>
              <select name="regimen" class="form-select">
                <% regimenes.forEach(r=>{ %>
                <option value="<%= r %>" <%=tercero&&tercero.regimen===r?'selected':''%>><%= r.replace(/_/g,' ') %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label fw-semibold small">Telefono</label>
              <input type="text" name="telefono" class="form-control"
                     value="<%= tercero&&tercero.telefono?tercero.telefono:'' %>" maxlength="20">
            </div>

            <div class="col-md-6">
              <label class="form-label fw-semibold small">Email <small class="text-muted">(Ley 1581)</small></label>
              <input type="email" name="email" class="form-control"
                     value="<%= tercero&&tercero.email?tercero.email:'' %>" maxlength="120">
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold small">Direccion <small class="text-muted">(Ley 1581)</small></label>
              <input type="text" name="direccion" class="form-control"
                     value="<%= tercero&&tercero.direccion?tercero.direccion:'' %>" maxlength="200">
            </div>

            <div class="col-md-4">
              <label class="form-label fw-semibold small">Ciudad</label>
              <input type="text" name="ciudad" class="form-control"
                     value="<%= tercero&&tercero.ciudad?tercero.ciudad:'' %>" maxlength="60">
            </div>
            <div class="col-md-4">
              <label class="form-label fw-semibold small">Departamento</label>
              <input type="text" name="departamento" class="form-control"
                     value="<%= tercero&&tercero.departamento?tercero.departamento:'' %>" maxlength="60">
            </div>
            <div class="col-md-4 d-flex align-items-end pb-1">
              <div class="form-check form-switch">
                <input class="form-check-input" type="checkbox" name="activo" id="activo"
                       <%=(!tercero||tercero.activo)?'checked':''%>>
                <label class="form-check-label small fw-semibold" for="activo">Activo</label>
              </div>
            </div>
          </div>

          <hr class="my-4">
          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary px-4"><i class="fas fa-save me-1"></i>Guardar</button>
            <a href="/terceros" class="btn btn-outline-secondary px-4">Cancelar</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
</div>
<%- include('../partials/foot') %>
