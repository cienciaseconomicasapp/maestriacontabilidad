<%- include('../partials/head') %>
<div class="d-flex">
<%- include('../partials/sidebar') %>
<div class="main-content w-100">
  <%- include('../partials/topbar') %>
  <div class="p-4">
    <%- include('../partials/alerts') %>
    <div class="card">
      <div class="card-header bg-white border-0 pt-3 px-4 d-flex justify-content-between align-items-center">
        <h6 class="fw-semibold mb-0"><i class="fas fa-chart-pie me-2 text-primary"></i>Presupuesto por Cuenta y Centro de Costo</h6>
        <a href="/presupuesto/nuevo" class="btn btn-primary btn-sm"><i class="fas fa-plus me-1"></i>Nuevo Presupuesto</a>
      </div>
      <div class="card-body">
        <div class="table-responsive">
          <table class="table table-hover dt">
            <thead class="table-light">
              <tr>
                <th>ID</th><th>Periodo</th><th>Cuenta</th><th>Centro de Costo</th>
                <th class="text-end">Valor Presupuestado</th><th>Acciones</th>
              </tr>
            </thead>
            <tbody>
              <% presupuestos.forEach(p=>{ %>
              <tr>
                <td><small class="text-muted"><%= p.id_pres %></small></td>
                <td><span class="badge bg-secondary"><%= p.periodo %></span></td>
                <td>
                  <code class="text-primary"><%= p.cuenta_codigo %></code>
                  <small class="d-block text-muted"><%= p.cuenta_nombre %></small>
                </td>
                <td><span class="badge bg-light text-dark border"><%= p.cc_codigo %></span> <small class="text-muted"><%= p.cc_nombre %></small></td>
                <td class="text-end fw-bold"><%= Number(p.valor_pres).toLocaleString('es-CO',{style:'currency',currency:'COP',maximumFractionDigits:0}) %></td>
                <td>
                  <a href="/presupuesto/<%= p.id_pres %>/editar" class="btn btn-sm btn-outline-primary me-1"><i class="fas fa-edit"></i></a>
                  <form method="POST" action="/presupuesto/<%= p.id_pres %>?_method=DELETE" class="d-inline"
                        onsubmit="return confirm('Eliminar este presupuesto?')">
                    <button class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></button>
                  </form>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
</div>
<%- include('../partials/foot') %>
