<%- include('../partials/head') %>
<div class="d-flex">
<%- include('../partials/sidebar') %>
<div class="main-content w-100">
  <%- include('../partials/topbar') %>
  <div class="p-4">
    <%- include('../partials/alerts') %>
    <div class="card" style="max-width:700px">
      <div class="card-header bg-white border-0 pt-3 px-4">
        <h6 class="fw-semibold mb-0"><%= pageTitle %></h6>
      </div>
      <div class="card-body px-4 pb-4">
        <form method="POST" action="<%= action %>">
          <div class="row g-3">

            <div class="col-md-4">
              <label class="form-label fw-semibold small">Periodo <span class="text-danger">*</span>
                <small class="text-muted fw-normal">AAAA-MM</small>
              </label>
              <input type="text" name="periodo" class="form-control"
                     value="<%= presupuesto?presupuesto.periodo:'' %>" required maxlength="7" placeholder="2024-01">
            </div>

            <div class="col-12">
              <label class="form-label fw-semibold small">Cuenta Contable <span class="text-danger">*</span></label>
              <select name="id_cuenta" class="form-select" required>
                <option value="">Seleccionar cuenta...</option>
                <% cuentas.forEach(c=>{ %>
                <option value="<%= c.id_cuenta %>" <%=presupuesto&&presupuesto.id_cuenta==c.id_cuenta?'selected':''%>>
                  <%= c.codigo %> - <%= c.nombre %>
                </option>
                <% }) %>
              </select>
            </div>

            <div class="col-12">
              <label class="form-label fw-semibold small">Centro de Costo <span class="text-danger">*</span></label>
              <select name="id_cc" class="form-select" required>
                <option value="">Seleccionar centro...</option>
                <% centros.forEach(c=>{ %>
                <option value="<%= c.id_cc %>" <%=presupuesto&&presupuesto.id_cc==c.id_cc?'selected':''%>>
                  <%= c.codigo %> - <%= c.nombre %>
                </option>
                <% }) %>
              </select>
            </div>

            <div class="col-md-6">
              <label class="form-label fw-semibold small">Valor Presupuestado <span class="text-danger">*</span></label>
              <div class="input-group">
                <span class="input-group-text">$</span>
                <input type="number" name="valor_pres" class="form-control"
                       value="<%= presupuesto?presupuesto.valor_pres:'' %>" required min="0" step="1">
              </div>
            </div>

          </div>
          <hr class="my-4">
          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary px-4"><i class="fas fa-save me-1"></i>Guardar</button>
            <a href="/presupuesto" class="btn btn-outline-secondary px-4">Cancelar</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
</div>
<%- include('../partials/foot') %>
