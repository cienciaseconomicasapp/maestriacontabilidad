<%- include('../partials/head') %>
<div class="d-flex">
<%- include('../partials/sidebar') %>
<div class="main-content w-100">
  <%- include('../partials/topbar') %>
  <div class="p-4">
    <%- include('../partials/alerts') %>
    <div class="card">
      <div class="card-header bg-white border-0 pt-3 px-4 d-flex justify-content-between align-items-center">
        <h6 class="fw-semibold mb-0"><i class="fas fa-file-invoice me-2 text-primary"></i>Comprobantes Contables</h6>
        <a href="/comprobantes/nuevo" class="btn btn-primary btn-sm"><i class="fas fa-plus me-1"></i>Nuevo Comprobante</a>
      </div>
      <div class="card-body">
        <div class="table-responsive">
          <table class="table table-hover dt">
            <thead class="table-light">
              <tr>
                <th>Consecutivo</th><th>Tipo</th><th>Fecha</th><th>Periodo</th>
                <th>Concepto</th><th>Tercero</th><th>Centro Costo</th>
                <th class="text-end">Valor Total</th><th>Estado</th><th>Acciones</th>
              </tr>
            </thead>
            <tbody>
              <% comprobantes.forEach(c=>{ %>
              <tr>
                <td><span class="badge bg-secondary"><%= c.prefijo %>-<%= String(c.numero).padStart(3,'0') %></span></td>
                <td><small class="text-muted"><%= c.tipo %></small></td>
                <td><small><%= c.fecha?new Date(c.fecha).toLocaleDateString('es-CO'):'-' %></small></td>
                <td><small><%= c.periodo||'-' %></small></td>
                <td style="max-width:220px" class="text-truncate"><small title="<%= c.concepto %>"><%= c.concepto %></small></td>
                <td><small><%= c.razon_social||'-' %></small></td>
                <td><small><%= c.cc_nombre||'-' %></small></td>
                <td class="text-end fw-semibold"><small><%= Number(c.valor_total).toLocaleString('es-CO',{style:'currency',currency:'COP',maximumFractionDigits:0}) %></small></td>
                <td><span class="badge es-<%= c.estado %>"><%= c.estado %></span></td>
                <td>
                  <a href="/comprobantes/<%= c.id_comp %>/editar" class="btn btn-sm btn-outline-primary me-1"><i class="fas fa-edit"></i></a>
                  <form method="POST" action="/comprobantes/<%= c.id_comp %>?_method=DELETE" class="d-inline"
                        onsubmit="return confirm('Eliminar comprobante <%= c.prefijo %>-<%= c.numero %>?')">
                    <button class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></button>
                  </form>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
</div>
<%- include('../partials/foot') %>
