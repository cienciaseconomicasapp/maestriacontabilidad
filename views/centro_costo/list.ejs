<%- include('../partials/head') %>
<div class="d-flex">
<%- include('../partials/sidebar') %>
<div class="main-content w-100">
  <%- include('../partials/topbar') %>
  <div class="p-4">
    <%- include('../partials/alerts') %>
    <div class="card">
      <div class="card-header bg-white border-0 pt-3 px-4 d-flex justify-content-between align-items-center">
        <h6 class="fw-semibold mb-0"><i class="fas fa-building me-2 text-primary"></i>Centros de Costo</h6>
        <a href="/centros-costo/nuevo" class="btn btn-primary btn-sm"><i class="fas fa-plus me-1"></i>Nuevo Centro</a>
      </div>
      <div class="card-body">
        <table class="table table-hover dt">
          <thead class="table-light">
            <tr>
              <th>ID</th><th>Codigo</th><th>Nombre</th><th>Descripcion</th><th>Estado</th><th>Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% centros.forEach(c=>{ %>
            <tr>
              <td><small class="text-muted"><%= c.id_cc %></small></td>
              <td><code class="fw-bold"><%= c.codigo %></code></td>
              <td><%= c.nombre %></td>
              <td><small class="text-muted"><%= c.descripcion||'-' %></small></td>
              <td><span class="badge" style="background:<%= c.activo?'#e8f5e9':'#fce4ec' %>;color:<%= c.activo?'#2e7d32':'#c62828' %>"><%= c.activo?'Activo':'Inactivo' %></span></td>
              <td>
                <a href="/centros-costo/<%= c.id_cc %>/editar" class="btn btn-sm btn-outline-primary me-1"><i class="fas fa-edit"></i></a>
                <form method="POST" action="/centros-costo/<%= c.id_cc %>?_method=DELETE" class="d-inline"
                      onsubmit="return confirm('Eliminar centro <%= c.codigo %>?')">
                  <button class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></button>
                </form>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
</div>
<%- include('../partials/foot') %>
