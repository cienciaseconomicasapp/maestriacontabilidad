<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Iniciar Sesion · ASC Contabilidad</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
<style>
  body { background: linear-gradient(135deg, #0d47a1 0%, #1565c0 50%, #1976d2 100%); min-height: 100vh; display: flex; align-items: center; }
  .login-card { border: none; border-radius: 18px; box-shadow: 0 25px 60px rgba(0,0,0,.35); }
</style>
</head>
<body>
<div class="container">
  <div class="row justify-content-center">
    <div class="col-sm-9 col-md-6 col-lg-4">
      <div class="card login-card p-4 p-md-5">
        <div class="text-center mb-4">
          <div style="background:#e3f2fd;width:70px;height:70px;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 12px">
            <i class="fas fa-calculator text-primary" style="font-size:1.8rem"></i>
          </div>
          <h5 class="fw-bold mb-0">ASC Contabilidad</h5>
          <p class="text-muted small mt-1">Maestria en Contabilidad<br>Universidad del Atlantico</p>
        </div>

        <% if(typeof error!=='undefined' && error.length>0) { %>
        <div class="alert alert-danger py-2 small"><i class="fas fa-exclamation-circle me-1"></i><%= error[0] %></div>
        <% } %>

        <form method="POST" action="/auth/login">
          <div class="mb-3">
            <label class="form-label fw-semibold small">Usuario</label>
            <div class="input-group">
              <span class="input-group-text"><i class="fas fa-user text-muted"></i></span>
              <input type="text" name="username" class="form-control" required autofocus placeholder="Nombre de usuario">
            </div>
          </div>
          <div class="mb-4">
            <label class="form-label fw-semibold small">Contrasena</label>
            <div class="input-group">
              <span class="input-group-text"><i class="fas fa-lock text-muted"></i></span>
              <input type="password" name="password" class="form-control" required placeholder="Contrasena">
            </div>
          </div>
          <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold">
            <i class="fas fa-sign-in-alt me-2"></i>Ingresar
          </button>
        </form>
      </div>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
