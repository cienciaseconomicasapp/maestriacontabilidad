# ============================================================
#  Variables de entorno - copiar a .env y completar valores
#  Railway inyecta MYSQLHOST, MYSQLPORT, etc. automaticamente
# ============================================================

# Base de datos MySQL (Railway MySQL plugin)
MYSQLHOST=localhost
MYSQLPORT=3306
MYSQLUSER=root
MYSQLPASSWORD=
MYSQLDATABASE=db_contabilidad_ua

# Sesion HTTP (cambiar por una cadena aleatoria larga)
SESSION_SECRET=cambia-esta-clave-secreta-2024

# Credenciales de acceso a la aplicacion web
ADMIN_USER=admin
ADMIN_PASSWORD=Admin2024UA

# Puerto (Railway lo asigna automaticamente via $PORT)
PORT=3000
